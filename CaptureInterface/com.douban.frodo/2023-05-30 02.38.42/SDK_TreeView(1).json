铺，我们陪你一起装点简单朴素但有质感的生活梦想。\n\n团购合作可添加微信（ID：D22763678）咨询，...展开","ContentDescription":"","visible":0,"isVisibleToUser":true,"coord":"0.0 146.0","dimensions":"998 1253","isClickable":true,"isFocusable":true,"isLongClickable":true,"isSelected":false,"canScroll":"false false false false","children":[]},{"id":197516378,"class":"androidx.appcompat.widget.AppCompatTextView","text":"品质好物，触手可得","ContentDescription":"","visible":0,"isVisibleToUser":true,"coord":"0.0 1399.0","dimensions":"533 160","isClickable":false,"isFocusable":false,"isLongClickable":false,"isSelected":false,"canScroll":"false false false false","children":[]},{"id":69166981,"class":"androidx.appcompat.widget.AppCompatTextView","text":"","ContentDescription":"","visible":8,"isVisibleToUser":true,"coord":"0.0 0.0","dimensions":"0 0","isClickable":false,"isFocusable":false,"isLongClickable":false,"isSelected":false,"canScroll":"false false false false","children":[]},{"id":59087720,"class":"android.widget.LinearLayout","text":"","ContentDescription":"","visible":0,"isVisibleToUser":true,"coord":"0.0 1559.0","dimensions":"998 64","isClickable":false,"isFocusable":false,"isLongClickable":false,"isSelected":false,"canScroll":"false false false false","children":[{"id":67006091,"class":"androidx.appcompat.widget.AppCompatTextView","text":"发言规则","ContentDescription":"","visible":0,"isVisibleToUser":true,"coord":"0.0 0.0","dimensions":"221 64","isClickable":false,"isFocusable":false,"isLongClickable":false,"isSelected":false,"canScroll":"false false false false","children":[]},{"id":262998913,"class":"com.douban.frodo.baseproject.view.button.FrodoButton","text":"2022年1月24日更新","ContentDescription":"","visible":0,"isVisibleToUser":true,"coord":"221.0 17.0","dimensions":"281 44","isClickable":false,"isFocusable":false,"isLongClickable":false,"isSelected":false,"canScroll":"false false false false","children":[]}]},{"id":147311066,"class":"com.douban.frodo.baseproject.view.spantext.EllipsizeAutoLinkTextView","text":"","C