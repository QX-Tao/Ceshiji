InParent":"(0, 0 - 188, 105)","boundsInScreen":"(41, 644 - 229, 749)"},{"index":3,"text":"在豆小铺：\n- 依时而食，不错过任何时令水果生鲜食材\n- 每月带你发掘一波新鲜零食小饮\n- 四季酒单供应，独酌聚会不愁嗨~\n- 让家成为一个可以舒服安心充电的地方\n- 收获一个美丽会穿又精神的自己！\n- 给你每一个节日的送礼灵感\n- 让好看又好用的小电器帮你解放双手！\n- ....更多吃喝玩乐生活家居，我们一起发掘~\n\n豆小铺是豆瓣官方的市集团购。这里汇聚了豆瓣上严苛又有爱的生活家、美食家，致力于挖掘那些能让你感到开心富足的生活好物。通过层层甄选并分享真实可感的使用体验，为你提供安心便利的购买服务。\n\n我们希望这些有温度的小物件，能够让你的日常变得更幸福一点点；在豆小铺，我们陪你一起装点简单朴素但有质感的生活梦想。\n\n团购合作可添加微信（ID：D22763678）咨询，...展开","resource-id":"com.douban.frodo:id\/group_intro","class":"android.widget.TextView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 998, 1253)","boundsInScreen":"(41, 790 - 1039, 2043)"},{"index":4,"text":"品质好物，触手可得","resource-id":"com.douban.frodo:id\/slogan","class":"android.widget.TextView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 533, 160)","boundsInScreen":"(41, 2043 - 574, 2203)"},{"index":5,"text":"发言规则","resource-id":"com.douban.frodo:id\/rules_title","class":"android.widget.TextView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 221, 64)","boundsInScreen":"(41, 2203 - 262, 2267)"},{"index":6,"text":"2022年1月24日更新","resource-id":"com.douban.frodo:id\/rules_update_time","class":"android.widget.TextView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":fal