长及组长合作的团长开团，参团请到各帖内按规则回复，其他无关讨论会被移除；2. 参团成功后，如有售后方面的问题，可以豆邮管理员@豆小铺小助理 咨询解决。温馨提醒：如果不想收到豆小铺发出的开团私信通知，可以在和小助理的豆邮\/私信界面，点击右上角「···」→「活动及推广信息设置」→关闭。","resource-id":"com.douban.frodo:id\/tv_group_intro","class":"android.widget.TextView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 998, 97)","boundsInScreen":"(41, 71 - 1039, 168)"},{"index":1,"text":"发言规则：1 请勿发布《社区指导原则》不允许的内容","resource-id":"com.douban.frodo:id\/tv_group_rules","class":"android.widget.TextView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 998, 49)","boundsInScreen":"(41, 168 - 1039, 217)"}]},{"index":6,"class":"android.widget.ImageButton","package":"com.douban.frodo","content-desc":"Navigate up","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 110, 154)","boundsInScreen":"(0, 93 - 110, 247)"},{"index":7,"resource-id":"com.douban.frodo:id\/toolbar_icon","class":"android.widget.ImageView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 83, 83)","boundsInScreen":"(111, 139 - 194, 222)"},{"index":8,"text":"豆小铺","resource-id":"com.douban.frodo:id\/toolbar_title","class":"android.widget.TextView","package":"com.douban.frodo","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scr