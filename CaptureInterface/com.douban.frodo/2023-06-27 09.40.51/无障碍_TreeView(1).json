children":[{"index":0,"class":"android.widget.Image","text":"","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 336 - 63, 396)"},{"index":1,"class":"android.widget.TextView","text":"个性化内容推荐算法说明","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(68, 327 - 649, 407)"},{"index":2,"class":"android.widget.TextView","text":"你可以在豆瓣发布、浏览、播放、创建、关注、收藏、点赞、转发、标记有关内容。我们会根据你的个人上网记录信息（指通过日志储存的操作记录，包括网站浏览记录、点击记录、收藏列表等）、你填写的个人基本资料信息（性别、生日、居住地），通过算法自动化决策机制分析你的喜好特征，以为你推荐、展示或推送相关程度更高的动态、广播、日记、话题、讨论、小组、书影音条目等内容。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 446 - 1042, 1018)"},{"index":3,"class":"android.widget.TextView","text":"\n","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 1018 - 1042, 1092)"},{"index":4,"class":"android.widget.TextView","text":"如你对豆瓣APP首页“推荐”中的内容不感兴趣，可点击该内容右上角“…”按钮，选择“不感兴趣”以拒绝类似内容的推荐。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 1086 - 1042, 1304)"},{"index":5,"class":"android.widget.TextView","text":"你也可以通过“个性化内容推荐与广告设置”页面调整或一键关闭豆瓣APP中所有个性化内容推荐。关闭个性化推荐后，我们仍会为你展示豆瓣热门和编辑精选内容。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 1304 - 1042, 1590)"}]},{"index":1,"resourceId":"text-LqcS9JtJeX0Dy3L31D4oQ","class":"android.view.View","text":"","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(22, 1590 - 1061, 2402)","children":[{"index":0,"class":"android.widget.Image","text":"","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 1689 - 63, 1749)"},{"index":1,"class":"android.widget.TextView","text":"个性化广告推荐算法说明","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(68, 1680 - 649, 1760)"},{"index":2,"class":"android.widget.TextView","text":"我们为你展示的个性化广告是指「程序化广告」和部分豆瓣商品信息。「程序化广告」指独立于豆瓣的第三方广告平台利用其自有的算法和信息，在豆瓣提供的广告展示空间中智能推荐的个性化广告。程序化广告推荐技术是一种常见、通行、安全的广告兴趣度适度匹配技术，其内容选择、展示与否由第三方广告平台决定，在此过程中，豆瓣仅提供对接技术及你的去标识化设备信息、网络信息、经你单独同意后获取的位置信息。豆瓣严格遵守法律法规，尊重并保护用户个人信息，不会获取你在第三方的行为数据。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":true,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 1799 - 1042, 2402)"},{"index":3,"class":"android.widget.TextView","text":"如果你对某个广告不感兴趣，可以点击该广告的按钮进行反馈，系统会减少为你推荐这一类型的广告。你也可以通过“个性化内容推荐与广告设置”页面一键关闭豆瓣上所有个性化广告推荐。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 2514 - 1042, 2402)"}]},{"index":2,"resourceId":"text-z-fc_iL0Bwr9ucCdvscCP","class":"android.view.View","text":"","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(22, 2800 - 1061, 2402)","children":[{"index":0,"class":"android.widget.Image","text":"","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 2899 - 63, 2402)"},{"index":1,"class":"android.widget.TextView","text":"排序算法说明","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(68, 2890 - 385, 2402)"},{"index":2,"class":"android.widget.TextView","text":"为向用户提供豆瓣站内的热点内容，提升用户获取热点内容的效率，豆瓣通过统计匿名化处理后的书影音条目内容的访问量、收藏、点赞、回复等信息，计算内容的热度值。并根据参与统计的数据时间范围的不同，又分为实时热度、近期热度和历史热度。结合热度值和时间因素，通过算法计算出不同类型的热门精选榜单的排序，排序结果为经过人工审核以及剔除不符合豆瓣社区价值导向的条目后生成最终的结果。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 3009 - 1042, 2402)"}]},{"index":3,"resourceId":"text-68HQ19cADAJmVILMPAILE","class":"android.view.View","text":"","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(22, 3581 - 1061, 2402)","children":[{"index":0,"class":"android.widget.Image","text":"","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 3680 - 63, 2402)"},{"index":1,"class":"android.widget.TextView","text":"搜索算法说明","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(68, 3671 - 385, 2402)"},{"index":2,"class":"android.widget.TextView","text":"为向用户提供更高效、便捷的搜索服务，展示更匹配用户搜索关键词的搜索结果，豆瓣基于深度学习的分词技术，给文档分词并建立倒排索引。通过倒排索引召回和用户输入关键词匹配的相关内容，并使用算法计算关键词和内容的相关性。同时豆瓣会根据内容文本质量、收藏、评论数量来计算内容热度和时效性。结合相关性、热度和时效性对召回结果排序，把相关性高，质量高的内容优先展现给用户。在搜索建议部分，豆瓣使用了前缀匹配技术，通过历史搜索频次统计热度排序，选择最可能搜索的关键词展现给用户。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 3790 - 1042, 2402)"},{"index":3,"class":"android.widget.TextView","text":"\n","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 4505 - 1042, 2402)"},{"index":4,"class":"android.widget.TextView","text":"如你对此有任何疑问、意见或建议，可以通过《豆瓣个人信息保护政策》中提示的联系方式联系我们，我们将尽快审核所涉问题，并在验证你的身份后，于15个工作日内进行回复。","contentDescription":"","canScroll":false,"isClickable":false,"isLongClickable":false,"isFocusable":false,"isFocused":false,"isVisibleToUser":false,"isSelected":false,"isEnabled":true,"boundsInScreen":"(38, 4573 - 1042, 2402)"}]}]}]}]}]}]}]}