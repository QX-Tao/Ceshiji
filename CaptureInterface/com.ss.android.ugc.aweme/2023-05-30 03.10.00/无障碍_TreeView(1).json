,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(69, 8 - 324, 38)","boundsInScreen":"(189, 126 - 891, 208)"}]},{"index":1,"text":"","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 45 - 394, 4142)","boundsInScreen":"(0, 227 - 1083, 2401)","children":[{"index":0,"text":"","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 30 - 377, 155)","boundsInScreen":"(44, 310 - 1036, 654)","children":[{"index":0,"text":"北京微播视界科技有限公司及其关联方（简称\"我们\"）作为抖音的运营者，深知个人信息对你的重要性，我们将按照法律法规的规定，保护你的个人信息及隐私安全。 本简明指引将帮助你直观、简明地了解我们是如何收集、处理使用个人信息以及如何保护你的隐私。更多详细信息请阅读完整的","class":"android.widget.TextView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 1 - 358, 125)","boundsInScreen":"(44, 313 - 1028, 654)"},{"index":1,"class":"android.view.View","package":"com.ss.android.ugc.aweme","content-desc":"《“抖音”隐私政策》","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(147, 104 - 277, 125)","boundsInScreen":"(448, 596 - 805, 654)","children":[{"index":0,"text":"《“抖音”隐私政策》","class":"android.widget.TextView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 130, 21)","boundsInScreen":"(448, 596 - 805, 654)"}]},{"index":2,"text":"。","class":"android.widget.TextView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(276, 104 - 291, 125)","boundsInScreen":"(803, 596 - 844, 654)"}]},{"index":1,"text":"1. 我们如何收集、使用信息","resource-id":"1. 我们如何收集、使用信息","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 179 - 377, 209)","boundsInScreen":"(44, 720 - 1036, 802)"},{"index":2,"text":"1.1 联络方式","resource-id":"1.1 联络方式","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 221 - 377, 247)","boundsInScreen":"(44, 835 - 1036, 907)"},{"index":3,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 255 - 377, 567)","boundsInScreen":"(44, 929 - 1036, 1787)","children":[{"index":0,"text":"【注册登录】你需要使用手机号码进行账号注册、登录。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 361, 42)","boundsInScreen":"(44, 929 - 1036, 1044)"},{"index":1,"text":"【与你联系】你的手机号码可能被用于向你发送运营、推广、活动等信息，或与你通过电话联系以处理调研访谈、投诉反馈等事宜。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 41 - 361, 104)","boundsInScreen":"(44, 1041 - 1036, 1215)"},{"index":2,"text":"【朋友推荐】如你授权我们使用你的通讯录权限，通讯录中的信息进行高强度加密算法处理后，用于向你推荐通讯录中的朋友。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 103 - 361, 167)","boundsInScreen":"(44, 1212 - 1036, 1388)"},{"index":3,"text":"【特别说明】如你不希望收到运营、推广、活动等信息，可以按照短信中的指定方式退订。如你不希望被推荐通讯录中的朋友，可拒绝授权或关闭通讯录权限。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 165 - 361, 229)","boundsInScreen":"(44, 1382 - 1036, 1558)"},{"index":4,"text":"【账号安全】为保障用户账号安全，在我们识别出你注册、登录账号所使用的手机号码有二次放号风险时，我们会将你的手机号码、账号注册\/登录时间提供给通信运营商做二次号查验，以保障你的账号安全。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 228 - 361, 312)","boundsInScreen":"(44, 1556 - 1036, 1787)"}]},{"index":4,"text":"1.2 账号信息","resource-id":"1.2 账号信息","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 574 - 377, 601)","boundsInScreen":"(44, 1806 - 1036, 1880)"},{"index":5,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 608 - 377, 733)","boundsInScreen":"(44, 1899 - 1036, 2243)","children":[{"index":0,"text":"【设置账号信息】当你注册账号，需要设置账号头像、昵称、密码。你可以选择填写性别、生日、地区及个人介绍等信息。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 361, 63)","boundsInScreen":"(44, 1899 - 1036, 2073)"},{"index":1,"text":"【使用第三方账号登录】当你使用第三方账号登录，你将授权我们获取你在第三方平台注册的公开信息（头像、昵称以及你授权的其他信息）。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 62 - 361, 125)","boundsInScreen":"(44, 2070 - 1036, 2243)"}]},{"index":6,"text":"1.3 设备、服务信息","resource-id":"1.3 设备、服务信息","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 740 - 377, 767)","boundsInScreen":"(44, 2262 - 1036, 2337)"},{"index":7,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 774 - 377, 983)","boundsInScreen":"(44, 2356 - 1036, 2401)","children":[{"index":0,"text":"【设备信息与日志信息】在软件与服务的安全运行过程中，我们会收集你的设备信息和日志信息。设备信息指设备型号、网络标识符、网络接入信息等与设备性能相关的信息，在手机终端中可能被表述为“电话信息”，这不代表 App 会收集通讯内容或你主动输入的隐私信息；日志信息指在你使用服务的过程中生成的服务日志。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 126)","boundsInScreen":"(44, 2356 - 1036, 2401)"},{"index":1,"text":"【特别说明】设备与日志信息也通常用在反作弊和判断账号是否处于安全的环境中。部分信息也可能被用于广告推送。目前多数手机系统可以支持对设备标识符的更改，具体方式可参见设备或厂商说明。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 125 - 361, 209)","boundsInScreen":"(44, 2700 - 1036, 2401)"}]},{"index":8,"text":"1.4 地理位置","resource-id":"1.4 地理位置","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 990 - 377, 1017)","boundsInScreen":"(44, 2950 - 1036, 2401)"},{"index":9,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1024 - 377, 1253)","boundsInScreen":"(44, 3043 - 1036, 2401)","children":[{"index":0,"text":"【内容推荐】为展示、推荐你所在地区（城市、区县等）的本地相关信息，需收集使用你的地理位置信息。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 42)","boundsInScreen":"(44, 3043 - 1036, 2401)"},{"index":1,"text":"【地址填写】为便于你填写地址信息，你可选择定位所在位置，以快速生成地址信息。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 41 - 361, 84)","boundsInScreen":"(44, 3156 - 1036, 2401)"},{"index":2,"text":"【朋友推荐】我们可能会基于你授权的精准地理位置信息向你推荐附近的人。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 83 - 361, 125)","boundsInScreen":"(44, 3272 - 1036, 2401)"},{"index":3,"text":"【特别说明】地理位置信息包括：（1）通过网络位置信息（例如 IP 及 WLAN）获取的大致地理位置信息；（2）通过 GPS 信息、WLAN 接入点、蓝牙和基站等信息获取到的精确地理位置信息。精确地理位置信息仅在你开启地理位置权限后才会被获取。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 124 - 361, 229)","boundsInScreen":"(44, 3384 - 1036, 2401)"}]},{"index":10,"text":"1.5 麦克风\/摄像头","resource-id":"1.5 麦克风\/摄像头","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1260 - 377, 1287)","boundsInScreen":"(44, 3692 - 1036, 2401)"},{"index":11,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1294 - 377, 1419)","boundsInScreen":"(44, 3786 - 1036, 2401)","children":[{"index":0,"text":"【发布内容】你拍摄视频、开启直播时，需要开启麦克风和摄像头权限。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 43)","boundsInScreen":"(44, 3786 - 1036, 2401)"},{"index":1,"text":"【扫码】你使用扫码功能时，需要开启摄像头权限。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 41 - 361, 63)","boundsInScreen":"(44, 3899 - 1036, 2401)"},{"index":2,"text":"【特别说明】我们绝不会私自开启麦克风、摄像头窃取你的隐私或收集你日常聊天时的对话，更不会采用此种非法手段进行信息、广告推送。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 62 - 361, 125)","boundsInScreen":"(44, 4733 - 1036, 6288)"}]},{"index":12,"text":"1.6 身份信息","resource-id":"1.6 身份信息","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1427 - 377, 1454)","boundsInScreen":"(44, 4152 - 1036, 2401)"},{"index":13,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1461 - 377, 1669)","boundsInScreen":"(44, 4245 - 1036, 2401)","children":[{"index":0,"text":"【实名认证】在开通直播、申请提现等特定场景下，你需要使用真实姓名、身份证号码等信息完成实名认证。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 42)","boundsInScreen":"(44, 4245 - 1036, 2401)"},{"index":1,"text":"【安全保障】在为验证身份、保障安全等特定必要场景下，你需要通过面部识别与身份证信息相结合的方式来认证你的身份。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 41 - 361, 105)","boundsInScreen":"(44, 4358 - 1036, 2401)"},{"index":2,"text":"【特别说明】你拍摄视频时可以使用人脸贴纸类型的功能，该功能不是人脸识别认证，仅是识别你的面部特征以实现更好的视觉效果，该识别仅在设备本地完成，不会通过人脸特征识别你个人身份，亦不会上传、存储或提供给第三方。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 103 - 361, 208)","boundsInScreen":"(44, 4528 - 1036, 2401)"}]},{"index":14,"text":"1.7 剪切板","resource-id":"1.7 剪切板","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1676 - 377, 1703)","boundsInScreen":"(44, 4836 - 1036, 2401)"},{"index":15,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1710 - 377, 1939)","boundsInScreen":"(44, 4930 - 1036, 2401)","children":[{"index":0,"text":"【分享、识别】在你分享或接收被分享的信息、参加活动、查看其他产品\/服务宣传内容等情形下，我们需要访问你的剪切板，读取其中包含的口令、分享码、链接，以实现跳转、分享、活动联动等功能或服务。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 84)","boundsInScreen":"(44, 4930 - 1036, 2401)"},{"index":1,"text":"【统计分析】我们可能需要将信息来源通过剪切板进行统计，在统计过程中我们不会将你写入剪切板的个人隐私信息回传。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 83 - 361, 147)","boundsInScreen":"(44, 5158 - 1036, 2401)"},{"index":2,"text":"【特别说明】有些手机等终端设备的系统会提示应用（App）正在读取剪切板，但该系统提示无法区分是否收集剪切板信息，且不排除误报。因此，如果你发现类似提示，请与我们联系，以便我们定位问题。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 145 - 361, 229)","boundsInScreen":"(44, 5329 - 1036, 2401)"}]},{"index":16,"text":"1.8 日历","resource-id":"1.8 日历","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1947 - 377, 1973)","boundsInScreen":"(44, 5582 - 1036, 2401)"},{"index":17,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 1980 - 377, 2065)","boundsInScreen":"(44, 5672 - 1036, 2401)","children":[{"index":0,"text":"【预约活动】当你选择预约视频、直播、活动时，需要开启设备日历权限。我们会访问你的日历，帮助你写入或编辑预约的视频、直播、活动的时间，以在约定时间向你发出日程提醒。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 85)","boundsInScreen":"(44, 5672 - 1036, 2401)"}]},{"index":18,"text":"1.9 使用信息","resource-id":"1.9 使用信息","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2072 - 377, 2098)","boundsInScreen":"(44, 5925 - 1036, 2401)"},{"index":19,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2105 - 377, 2293)","boundsInScreen":"(44, 6016 - 1036, 2401)","children":[{"index":0,"text":"【使用行为】你使用时，我们将记录你的点击、评论、关注、点赞、收藏、搜索、浏览、分享等行为。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 43)","boundsInScreen":"(44, 6016 - 1036, 2401)"},{"index":1,"text":"【内容发布】当你主动发布内容时，我们将记录你发布的视频、直播、图片、文字等内容。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 42 - 361, 85)","boundsInScreen":"(44, 6132 - 1036, 2401)"},{"index":2,"text":"【在线状态】我们会向与你互相关注的用户展示你的账号的在线状态，告知你朋友你是否在线或曾经在线的时间。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 83 - 361, 147)","boundsInScreen":"(44, 6244 - 1036, 2401)"},{"index":3,"text":"【特别说明】上述信息是对你使用抖音各项功能的实际情况的记录。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 146 - 361, 188)","boundsInScreen":"(44, 6418 - 1036, 2401)"}]},{"index":20,"text":"1.10 传感器信息","resource-id":"1.10 传感器信息","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2300 - 377, 2327)","boundsInScreen":"(44, 6552 - 1036, 2401)"},{"index":21,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2334 - 377, 2626)","boundsInScreen":"(44, 6646 - 1036, 2401)","children":[{"index":0,"text":"【内容发布】你使用抖音中提供的道具、特效、滤镜、贴纸等工具拍摄并发布内容时，我们会根据你的操作及使用的工具类型使用加速度传感器、陀螺仪传感器、重力传感器等设备传感器，以适配你选用的工具。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 84)","boundsInScreen":"(44, 6646 - 1036, 2401)"},{"index":1,"text":"【播放适配】当你播放视频等内容时，为了适配你的设备状态，我们会调用设备的重力、加速度等传感器，以识别你的设备横竖屏状态。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 83 - 361, 147)","boundsInScreen":"(44, 6874 - 1036, 2401)"},{"index":2,"text":"【动作互动】当你进行“摇一摇”、“抖一抖”、“走路”等依赖于动作开展的互动或活动时，我们会使用你的加速度传感器、陀螺仪传感器、重力传感器、计步传感器、步态检测传感器等设备传感器（单纯的传感器数据不属于个人信息），以识别你的动作，用于活动参与或为你展示下一步互动场景，或向你提供持续的运动记录以便于你参与活动。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 145 - 361, 292)","boundsInScreen":"(44, 7045 - 1036, 2401)"}]},{"index":22,"text":"2. 主要功能或服务中个人信息的使用","resource-id":"2. 主要功能或服务中个人信息的使用","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2638 - 377, 2667)","boundsInScreen":"(44, 7482 - 1036, 2401)"},{"index":23,"text":"2.1 内容推荐：推荐你可能更感兴趣的内容","resource-id":"2.1 内容推荐：推荐你可能更感兴趣的内容","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2680 - 377, 2707)","boundsInScreen":"(44, 7597 - 1036, 2401)"},{"index":24,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2714 - 377, 2902)","boundsInScreen":"(44, 7691 - 1036, 2401)","children":[{"index":0,"text":"为实现向你推荐可能更感兴趣的资讯信息，我们会收集使用信息、设备信息、位置信息，服务端结合这些信息向你提供个性化内容推荐服务。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 63)","boundsInScreen":"(44, 7691 - 1036, 2401)"},{"index":1,"text":"我们会综合统计你的设备信息、位置信息、你在使用抖音时的行为信息、你填写的个人资料，以及经你授权从抖音中收集或由其他合作方提供的其他信息，并通过算法做特征与偏好分析，预测你的偏好特征，用以向你进行推荐、展示或推送你可能感兴趣的信息，或者推送更适合你的特定功能、服务。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 62 - 361, 188)","boundsInScreen":"(44, 7861 - 1036, 2401)"}]},{"index":25,"text":"2.2 朋友推荐：推荐你可能认识的人","resource-id":"2.2 朋友推荐：推荐你可能认识的人","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2909 - 377, 2935)","boundsInScreen":"(44, 8227 - 1036, 2401)"},{"index":26,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 2943 - 377, 3068)","boundsInScreen":"(44, 8321 - 1036, 2401)","children":[{"index":0,"text":"我们可能会根据你的账号信息、使用信息、地理位置等向你推荐可能认识的人。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 42)","boundsInScreen":"(44, 8321 - 1036, 2401)"},{"index":1,"text":"我们可能会请求通讯录权限，并将通讯录中的信息进行高强度加密算法处理后，用于向你推荐通讯录中的朋友。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 41 - 361, 104)","boundsInScreen":"(44, 8433 - 1036, 2401)"},{"index":2,"text":"如果你不希望被推荐给朋友，可以在设置中关闭。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 103 - 361, 125)","boundsInScreen":"(44, 8604 - 1036, 2401)"}]},{"index":27,"text":"2.3 广告推送：向你发布商品或服务的推广信息","resource-id":"2.3 广告推送：向你发布商品或服务的推广信息","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 3075 - 377, 3127)","boundsInScreen":"(44, 8684 - 1036, 2401)"},{"index":28,"text":"","class":"android.widget.ListView","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(16, 3135 - 377, 3343)","boundsInScreen":"(44, 8849 - 1036, 2401)","children":[{"index":0,"text":"我们会向你发布商品或服务的推广信息（广告），其中包括根据你的喜好进行推荐的信息，也包括不具有特定性的普遍发布的信息。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 361, 63)","boundsInScreen":"(44, 8849 - 1036, 2401)"},{"index":1,"text":"我们可能与进行推广和广告投放的合作伙伴共享信息，但我们会采取必要的技术手段，在不识别你个人身份的前提下向你提供更为相关的推广信息。","class":"android.view.View","package":"com.ss.android.ugc.aweme","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 62 - 361, 125)","bound