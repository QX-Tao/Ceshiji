dlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 242 - 393, 356)","boundsInScreen":"(0, 890 - 1080, 1204)"},{"index":4,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 355 - 393, 431)","boundsInScreen":"(0, 1201 - 1080, 1410)","children":[{"index":0,"text":"闲鱼币使用说明","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 52 - 373, 76)","boundsInScreen":"(55, 1344 - 1025, 1410)"}]},{"index":5,"text":"1、\t会员可使用闲鱼币用以兑换、竞拍、抵扣购买（比例及数量等以具体页面说明为准）闲鱼或阿里特定业务的相关商品或服务。当闲鱼币抵扣的订单出现改价或部分退货退款时，订单中抵扣所使用的闲鱼币不予退还；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 430 - 393, 566)","boundsInScreen":"(0, 1407 - 1080, 1781)"},{"index":6,"text":"2、\t会员可通过消耗闲鱼币报名参与相应活动。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 565 - 393, 635)","boundsInScreen":"(0, 1778 - 1080, 1971)"},{"index":7,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 634 - 393, 711)","boundsInScreen":"(0, 1968 - 1080, 2180)","children":[{"index":0,"text":"注意事项","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 53 - 373, 77)","boundsInScreen":"(55, 2114 - 1025, 2180)"}]},{"index":8,"text":"1、\t会员账户一旦被查封，该账户的闲鱼币及闲鱼币权益将同步失效。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 710 - 393, 780)","boundsInScreen":"(0, 2177 - 1080, 2370)"},{"index":9,"text":"2、\t闲鱼币及闲鱼币权益仅供会员本人使用，不可转赠，不可用于兑换现金。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 779 - 393, 791)","boundsInScreen":"(0, 2367 - 1080, 2400)"},{"index":10,"text":"3、\t当会员账户中的闲鱼币不足以抵扣其已兑换的闲鱼币权益时，闲鱼将从会员后续获得的闲鱼币中进行相应抵扣。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":11,"text":"4、\t会员应按平台规定正当获取并使用闲鱼币，对任何涉嫌非正当途径（如通过第三方软件、利用网络漏洞、恶意套现、刷取信誉、虚假交易等）获取或使用闲鱼币，或影响闲鱼币正常运营的行为，闲鱼有权收回会员账户及关联账户中的闲鱼币，并取消相应的闲鱼币权益。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":12,"text":"5、\t闲鱼可根据活动实际情况，在法律允许范围内，对活动规则进行变动或调整，相关变动将公布在活动页面。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"}]}]}]}]}]}]}]}