9 - 393, 791)","boundsInScreen":"(0, 2202 - 1080, 2400)"},{"index":12,"text":"3. 超级夺宝奖品最多可兑换10000个幸运号，精选夺宝奖品最多可兑换3个幸运号。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":13,"text":"4. 每个夺宝活动都有开奖人数要求，只有参与人数达到要求活动才会开奖。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":14,"text":"5. 未达到参与人数要求的夺宝活动将不予开奖，官方将退还会员参与活动时消耗的闲鱼币。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":15,"text":"6. 达到开奖人数要求的夺宝活动，若用户未中奖，官方不退还任何闲鱼币。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":16,"text":"7. 活动开奖后，闲鱼会将中奖信息以站内消息的形式推送给每一位中奖会员。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":17,"text":"8. 中奖会员可点击消息或活动详情页中领取宝贝按钮跳转至领取宝贝页面。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":18,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)","children":[{"index":0,"text":"奖品发放规则","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 2397 - 1025, 2400)"}]},{"index":19,"text":"请中奖用户在相对应的中奖链接中以0.01元的价格拍下奖品并完成付款（该奖品中奖链接为定向发送，转发他人领奖无效），如中奖用户在中奖链接发出后24个小时内没有拍下或未完成付款的，视为放弃中奖机会。在中奖用户按要求拍下付款后30天内，奖品将按用户拍下时提供的收货地址发货。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"}]}]}]}]}]}]}]}