en":"(0, 225 - 1080, 2400)","children":[{"index":0,"class":"com.uc.webkit.bb","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 2324 - 1080, 4499)","boundsInScreen":"(0, 225 - 1080, 2400)","children":[{"index":0,"text":"闲鱼圈主公约","class":"android.webkit.WebView","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":true,"scrollable":true,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 845 - 393, 1636)","boundsInScreen":"(0, 225 - 1080, 2400)","children":[{"index":0,"text":"","resource-id":"root","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 791)","boundsInScreen":"(0, 225 - 1080, 2400)","children":[{"index":0,"text":"","resource-id":"recyclerview","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 791)","boundsInScreen":"(0, 225 - 1080, 2400)","children":[{"index":0,"text":"","resource-id":"9934703540","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 791)","boundsInScreen":"(0, 225 - 1080, 2400)","children":[{"index":0,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"闲鱼圈主公约","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":1,"text":"亲爱的闲鱼用户： 闲鱼会玩圈子致力于为闲鱼用户提供安全友好的交流分享社区。为了维护良好的圈子氛围，圈主应依据本公约和闲鱼相关规则对已加入圈子的用户和发布在圈子的内容进行管理。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)"},{"index":2,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"一、圈主上任","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":3,"text":"【圈主上任资格】 \r\n1.圈主账户及关联账户不存在严重违规、出售假冒商品等违规行为，芝麻信用分良好且已满18周岁，并通过实名认证和实人认证； \r\n2.近30天登录闲鱼天数大于等于10天； \r\n3.圈主申请提交后3个工作日内审核人员会将审核结果通知到申请人； \r\n4.成为圈主后需接受闲鱼的监督和管理，且仅能担任1个圈子的圈主； \r\n5.圈子创建后，圈主需要在15天内完成新手任务，完成所有任务后即视为创建成功。 \r\n\r\n【圈主汰换】 \r\n1.圈主如存在严重违规行为（如涉嫌欺诈、发布或置顶违禁信息\/假冒商品等）将被撤销圈主资格； \r\n2.圈主需承担圈子管理工作，如长时间未参与圈子管理行为，且在闲鱼对圈主警告提示后仍无改进措施，将撤销圈主权限，圈主管理工作包括： \r\n· 圈子运营行为（包括创建\/删除话题、圈子内发布商品\/帖子、圈子内给圈民的商品留言\/点赞、置顶\/屏蔽\/删除\/举报圈子内的帖子、举报圈子内的商品\/评论、拉黑\/举报圈民等） \r\n· 处理圈子消息（包括回复圈民消息等） \r\n3.圈主不得滥用、恶意利用闲鱼所赋予的各项权利损害他人合法权益、妨害闲鱼运营秩序的行为，一经发现闲鱼可撤销其圈主资格。\r\n4.圈主需接受闲鱼用户及闲鱼社区的监督，当圈主的管理行为有悖于本公约或闲鱼社区相关规则时，闲鱼可更换圈主；同时，闲鱼可根据闲鱼用户体验需要、圈子内违规等情况屏蔽、降权或关停相关圈子。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 193)","boundsInScreen":"(0, 225 - 1080, 755)"},{"index":4,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 192 - 393, 268)","boundsInScreen":"(0, 753 - 1080, 962)","children":[{"index":0,"text":"二、圈子管理要求","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 52 - 373, 76)","boundsInScreen":"(55, 896 - 1025, 962)"}]},{"index":5,"text":"1.协助维护圈子的信息安全\r\n · 圈子不得出现国家法律法规所不允许发布的信息，包括：枪支弹药、军警用品、危险武器、易燃易爆、危险化学品、毒品、色情低俗、药品、医疗器械、非法服务、违反公序良俗等信息；\r\n · 圈子不得出现假冒商品、侵犯他人合法权益的信息，包括：侵犯他人商标权、著作权、专利权、肖像权及未经合法授权的图片、文字等信息；\r\n · 圈子不得出现食品、酒类、医疗器械等须资质准入的商品，包括：婴幼儿类食品、奶粉、保健食品、酒类、预包装食品、二类医疗器械等相关商品； \r\n· 圈子不得出现拉人炒信、兼职广告等垃圾广告信息；\r\n· 圈子不得出现引导或提供闲鱼站外联系方式的信息，包括：外部网站的链接、文字、图片、二维码等；\r\n· 圈子不得出现涉及媒体舆情的违法违规或可能引发他人人身财产伤害的相关内容，包括：经新闻媒体曝光、国家质监部门等行政管理部门通报或其他要求协查的商品及信息； \r\n· 圈子不得出现的其他违规信息，详见《闲鱼社区管理规范》。 圈主应积极屏蔽或举报违反上述要求或可能存在安全隐患的商品、帖子、评论或用户。 \r\n\r\n2.协助建立维护圈子的友好氛围 \r\n· 圈子不得出现以侮辱、诽谤、嘲讽、威胁、挑衅等方式对他人进行人身攻击或其他不友善的信息；\r\n· 圈子不得出现泄露他人隐私的信息，包括：未经他人许可公开他人真实姓名、身份证号、电话号码、住址等隐私信息； 圈主应积极屏蔽或举报可能存在违反上述要求的商品、帖子、评论或用户，积极屏蔽与圈子主题无关的商品或帖子，并不得以任何形式组织或鼓励虚假交易、评价或互动行为，为圈民提供信息纯净、友好的圈子氛围。 \r\n\r\n3.协助圈子获得健康积极的发展 \r\n·圈主需保证及时处理圈内违规和不相关内容、商品，维护好圈子相关性和氛围。 \r\n·积极参与闲鱼活动，协助闲鱼做好圈子共建。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 267 - 393, 791)","boundsInScreen":"(0, 959 - 1080, 2400)"},{"index":6,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)","children":[{"index":0,"text":"三、特别说明","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 2397 - 1025, 2400)"}]},{"index":7,"text":"本公约中已有规定的从本公约，本公约未有规定的依据《闲鱼社区公约》等相关规则执行。 本公约于2021年4月20日首次生效，与2021年12月 17日最新修订生效","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"}]}]}]}]}]}]}]}