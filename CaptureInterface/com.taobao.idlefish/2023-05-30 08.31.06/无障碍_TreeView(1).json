d.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 267 - 393, 316)","boundsInScreen":"(0, 957 - 1080, 1091)"},{"index":5,"text":"1.已完成实人认证，且账户状态正常；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 315 - 393, 363)","boundsInScreen":"(0, 1089 - 1080, 1221)"},{"index":6,"text":"2.昵称、头像、简介内容填写完整；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 362 - 393, 410)","boundsInScreen":"(0, 1218 - 1080, 1350)"},{"index":7,"text":"3.闲气值≥90分；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 409 - 393, 457)","boundsInScreen":"(0, 1347 - 1080, 1479)"},{"index":8,"text":"4.粉丝量≥1000；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 456 - 393, 504)","boundsInScreen":"(0, 1476 - 1080, 1608)"},{"index":9,"text":"5.累计发布原创优质帖子数≥30；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusa