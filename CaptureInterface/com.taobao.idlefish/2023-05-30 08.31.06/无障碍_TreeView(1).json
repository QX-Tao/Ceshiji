80, 2400)"},{"index":1,"text":"1.主动退出：可申请主动退出","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":2,"text":"2.被清退","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":3,"text":"(1)不符合准入要求；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":4,"text":"(2)发布的商品或帖子领域发生变化，与所认证的玩家领域不符；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":5,"text":"(3)存在相关违规行为。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"}]},{"index":3,"text":"","resource-id":"7490791380","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 872 - 393, 873)","boundsInScreen":"(0, 2398 - 1080, 2400)","children":[{"index":0,"text":"三、再准入","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":1,"text":"1.主动退出：自主动退出之时起24小时后方可申请再准入。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":2,"text":"2.被清退：自清退之日起30天后方可申请。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":3,"text":"说明：","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":4,"text":"以下情形一经发现将回收“闲鱼玩家”头衔。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":5,"text":"1.闲鱼鼓励用户发布原创内容，若内容被投诉或经平台巡检发现存在侵权、抄袭等行为，平台认定属实的，平台将视为严重违反平台规范进行处理，并回收闲鱼玩家头衔。严重违规者还将面临账号扣分、封禁等处罚。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":6,"text":"2.通过刷粉、刷单、重复发布同一件商品、重复发布同一篇帖子等作弊行为完成玩家身份认证，平台将回收“闲鱼玩家”头衔。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":7,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)","children":[{"index":0,"text":"第三条 【其他】","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 2398 - 1025, 2400)"}]},{"index":8,"text":"1.本规范为闲鱼社区规则（包括《闲鱼社区公约》、《闲鱼社区管理规范》等）的下位规范。闲鱼社区规则已有规定的，从其规定；未有规定或本规范有特殊规定的，按照本规范执行。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":9,"text":"2.闲鱼社区、闲鱼论坛、帮助中心、闲鱼玩家认证所在功能页面等发布的相关规则、提示文案、公告等内容均为本规范的补充，与本规范不可分割且具有同等法律效力。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":10,"text":"3.闲鱼可能根据业务的发展等变更本规范，并就变更内容通过闲鱼社区站内信、系统消息或以其他形式通知您，请您应及时查看。如您不同意相关变更，应立即申请退出闲鱼玩家；如您继续使用的，视为同意变更后的规范。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"},{"index":11,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)","children":[{"index":0,"text":"第四条 【生效时间】","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 2398 - 1025, 2400)"}]},{"index":12,"text":"本规范于2022年7月4日首次生效，于2023年2月15日最新修订。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 2398 - 1080, 2400)"}]}]}]}]}]}]}]}