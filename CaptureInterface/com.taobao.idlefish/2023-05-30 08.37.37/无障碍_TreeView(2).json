index":0,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"食品\/图书资质卖家发布说明","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":1,"text":"『各位卖家，闲鱼社区已于2022年11月全面升级食品\/图书商品规范经营发布链路，请各位仔细阅读公告说明并按照内容要求亮照及规范发布宝贝。』","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)"},{"index":2,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"一、亮照经营范围说明","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":3,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"O1CN01DPOLP31eJLf9kz5EK_!!6000000003850-2-tps-745-377.png_790x10000.jpg_","class":"android.widget.Image","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":4,"text":"⭐️注意：如对经营范围仍有疑惑，最终以“发布商品提示”为准，如发布商品是有以下提示请尽快完成亮照","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)"},{"index":5,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"O1CN01mHj0UJ1H1Grw2VLkx_!!6000000000697-0-tps-620-522.jpg_790x10000Q75.jpg_","class":"android.widget.Image","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":6,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"二、亮照流程","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":7,"text":"1、上传资质图示说明\n①第1步：上传个体工商户或企业营业执照（个人声明无效），直接点击下方按钮“立刻去开通” \n②第2步：完成营业执照亮照审核通过后，再上传特许经营资质\n在闲鱼APP内点击【我的】右上角-【设置】-【个人资料设置】-【经营资质】-【特许经营资质】（如图书、食品、酒）上传，等待审核通过 \n⭐️注意：请确认营业执照主体、特许经营资质主体和闲鱼账号实名认证主体一致，特许经营资质审核环节将会进行校验，请务必保证提供的法人身份证信息、法人支付宝账号实名认证信息和资质显示法人信息一致！","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)"},{"index":8,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 1)","boundsInScreen":"(0, 225 - 1080, 227)","children":[{"index":0,"text":"O1CN01QDoUho1X6nV0sosuM_!!6000000002875-2-tps-662-1073.png_790x10000.jpg_","class":"android.widget.Image","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 225 - 1025, 227)"}]},{"index":9,"text":"2、亮照常见问题答疑 \n①卖家需要上传哪些经营资质？\n●预包装食品类：需要办理个体工商户或企业类型的营业执照和食品经营相关许可资质，经营范围均需包含食品类，其中食品销售许可资质包含“食品经营许可证”or“预包装食品销售备案凭证”or“食品生产许可证”or“小作坊许可证”均可。\n⭐️注意：如当地政策不同，无需以上证件，请您先查看营业执照，经营范围是否包含【仅销售预包装食品】见下图说明，如果已有，直接在【预包装食品销售备案凭证】入口，证照图片使用《营业执照》备案即可，有效期最高填写5年","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 141)","boundsInScreen":"(0, 225 - 1080, 612)"},{"index":10,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 140 - 393, 415)","boundsInScreen":"(0, 610 - 1080, 1366)","children":[{"index":0,"text":"O1CN01LuPSIh29zFzp2bRxo_!!6000000008138-2-tps-569-403.png_790x10000.jpg_","class":"android.widget.Image","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 26 - 373, 275)","boundsInScreen":"(55, 681 - 1025, 1366)"}]},{"index":11,"text":"● 图书类：需要办理个体工商户或企业类型的营业执照和出版物经营许可证，营业执照经营范围含图书\/出版物销售。上传出版物经营许可证时需同时上传正本、副本原件照片，不可单独上传 \n● 资质有效期：有效截止时间以资质显示为准，如无明确截止日期或系统无法选择长期，一律选择5年\n⭐️注意：新办理的执照市场监管局很可能未上传系统，建议等3-7天再亮照，另所有证件的有效截止日期需大于60天","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 414 - 393, 682)","boundsInScreen":"(0, 1363 - 1080, 2100)"},{"index":12,"text":"②上传特许资质时经营范围如何选择？ \n● 经营范围选择原则：资质中经营范围包含什么上传系统选择时务必按照实际情况选择，与资质保持一致 \n● 特殊品类说明：经营“酒”品类，勾选经营范围时，必须勾选上酒类（如有单独的选项）；如当地政策经营范围只显示了“预包装食品”，但包含了酒类也必须选上，否则发布不了","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 681 - 393, 791)","boundsInScreen":"(0, 2097 - 1080, 2400)"},{"index":13,"text":"③上传许可证资质时需要注意事项，许可证编码如何填写？\n● 食品经营许可编码不要填写错误，不是信用代码 是 “许可证编码”","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":14,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)","children":[{"index":0,"text":"O1CN015HMa1q1aCF3SDUv8R_!!6000000003293-0-tps-550-264.jpg_790x10000Q75.jpg_","class":"android.widget.Image","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 2397 - 1025, 2400)"}]},{"index":15,"text":"● 出版物许可证编号请按证照上的信息对应填写完整，“新出发XX批字第XXX号”格式","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":16,"text":"④注册时，想要使用企业支付宝进行校验该如何操作？\n如果您选择用企业支付宝，请按照以下流程操作：注册闲鱼账号→发布商品→触发跳转绑定支付宝（企业支付宝）→授权同步实名信息；\n⭐️注意：部分用户使用企业支付宝时曾存在系统对接问题影响校验，您也可以选择使用法人个人支付宝进行校验。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":17,"text":"⑤同一资质证件最多能认证多少个闲鱼账号？  \n同一资质证件最多可支持三个闲鱼账号认证，需保证特许经营资质主体和闲鱼账号实名认证主体一致。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":18,"text":"⑥特许经营资质审核时效是多久？  \n证照提交后审核时间预计为2个工作日（法定节假日预计顺延），证照审核通过后，方可发布对应类型商品。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":19,"text":"⑦如我的经营信息变更或更换了新的证照怎么办？ \n●  如经营信息变更，您可以在【经营者资质管理】页面下线旧证照并添加新的有效证照。为避免影响卖家正常业务经营，如果您的资质有变动，请您及时更新 \n● 如原先使用了个人声明亮照现要改成营业执照亮照，在资质管理页面，我的经营资质点击右上角“增加类型”即可","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":20,"text":"⑧资质提交时需要填写的证照核实方式的官方链接哪里获取?（填写后台也有说明） \n● 请提供证照在官网的展示链接（您可联系当地发证机关，确认证照核验网址）  \n● 目前淘宝收录的部分网址，查看请点击https:\/\/helpcenter.taobao.com\/learn\/knowledge?version=old&id=24138570&referer=https%3A%2F%2Fx-space.taobao.com%2F \n● 若证照上包含二维码，您可以扫描证照上的二维码后，将对应的网页链接复制后提供","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":21,"text":"⑨上传特许经营资质证照后，会有什么好处？\n● 按照资质许可范围在闲鱼从事经营性的图书、食品、酒、茶类目商品交易；  \n● 受邀开通鱼小铺工具（账号闲气值需＞80分，在线商品数＞1），享宝贝分组、专属曝光卡、粉丝抽奖、设置多规格宝贝等专属权益，同时宝贝发布数量可提升至500个；  \n● 平台活动资源支持","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":22,"text":"⑩上传特许经营资质证照后，需要履行什么样的义务和责任？  \n作为具备相关资质并进行商业经营活动的经营性卖家，也即展示“商”字标的经营性卖家，应履行相关法律法规、平台服务保障要求及您的保障承诺。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":23,"text":"⑪如何取消特许资质亮证亮照？取消特许资质亮照或到期未及时更新资质会有什么影响？\n● 如您在【经营者资质管理】页面下线某特许经营资质，对应类目发布权限会被即刻关闭，对应类目已上架的商品会被下架处理；  \n● 如您在【闲鱼资质管理】页面点击【取消亮照】，31天公示期后，您在闲鱼上传的所有资质都将失效，对应类目发布权限会被关闭，对应类目已上架的商品会被下架处理。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":24,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)","children":[{"index":0,"text":"三、商品发布规范要求","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 2397 - 1025, 2400)"}]},{"index":25,"text":"发布商品时请注意类目正确，请勿错挂类目，如发布至【其他闲置】。错挂类目易违规，甚至导致被封号","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":26,"text":"1、标题规范：尽量写满30字。利益点关键词可以打头标注，如“全新、正品、清仓、自产自销等等”；","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":27,"text":"2、商品信息发布要求： \n①食品类： \n● 不得发布保质期小于等于30天的商品，包含但不限于临期品（冷藏冷冻短保质期食品除外）； \n● 商品的描述信息（文字或者商品图片）如商品标题、图片、属性区域、详情描述等信息保证要素一致性；  \n● 预包装食品发布时上传的宝贝图片须包含实物图，图中能清晰展示配料表、食品生产许可证编号、执行标准、贮存条件、营养成份表、产品标准代码、生产日期、保质期等信息；  \n● 须如实描述商品的实际功效，不得含有虚假、夸大的内容，不得涉及治病预防、治疗等功效描述，不得真人展示效果，所描述内容须与国家批准的实物外包装说明信息内容一致：\n1）转基因食品，应当按照规定显著标示； \n2）特许养殖类商品，不得出现“野生”、“野外”、“非家养”等误导性用词；\n● 不得发布特殊医学用途配方食品、婴幼儿配方乳粉；\n● 食用天期大于 90 天商品，需页面提示用户食用天期。  \n ②图书类： \n● 图书发布时请扫描ISBN编码，多本书请勿发在同一个ISBN编码下，请勿发布在同一个商品链接下；\n● 90年代以前没有编码的老书和境外采购的图书无法发布；\n● 图书内容安全风险需把控，如禁书、作者违规，涉及迷信涉政涉色情等，都需小心谨慎，如坚持发布违规后果需自担 ；\n● 图书版权风险，如发布全新无授权盗版影印书，易发生权利所有人投诉盗版违规，如无授权无货源一件代发自行发布，违规后果需自担。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)"},{"index":28,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 790 - 393, 791)","boundsInScreen":"(0, 2397 - 1080, 2400)","children":[{"index":0,"text":"O1CN01tLodcu26QxUF8XQHK_!!6000000007657-2-tps-760-30.png_790x10000.jpg_","class":"android.widget.Image","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(20, 0 - 373, 1)","boundsInScreen":"(55, 2397 - 1025, 2400)"}]}]},{"index":1,"text":"","resource-id":"3103411930","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(16, 0 - 377, 1)","boundsInScreen":"(44, 225 - 1036, 227)","children":[{"index":0,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 361, 1)","boundsInScreen":"(44, 225 - 1036, 227)","children":[{"index":0,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 361, 1)","boundsInScreen":"(44, 225 - 1036, 227)","children":[{"index":0,"text":"O1CN01qSPHjF1w30ahieR8Q_!!6000000006251-2-tps-1029-171","class":"android.widget.Image","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 361, 1)","boundsInScreen":"(44, 225 - 1036, 227)"}]}]}]}]}]}]}]}]}]}