ibleToUser":true,"boundsInParent":"(0, 81 - 393, 873)","boundsInScreen":"(0, 222 - 1080, 2400)","children":[{"index":0,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 0 - 393, 77)","boundsInScreen":"(0, 222 - 1080, 434)","children":[{"index":0,"text":"勋章规则说明","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(20, 53 - 373, 77)","boundsInScreen":"(55, 368 - 1025, 434)"}]},{"index":1,"text":"1.怎样才能获得勋章？","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 76 - 393, 124)","boundsInScreen":"(0, 431 - 1080, 563)"},{"index":2,"text":"每个勋章的具体达成规则会有所不同，具体请查看每一个勋章的卡片页面。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 123 - 393, 193)","boundsInScreen":"(0, 561 - 1080, 753)"},{"index":3,"text":"2.勋章什么时候发放、会被收回吗？","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 192 - 393, 240)","boundsInScreen":"(0, 750 - 1080, 882)"},{"index":4,"text":"除了部分纪念型的限量版勋章外，其他勋章都是有效期的，勋章会进行动态更新，具体更新时间根据每个勋章的实际情况而定，一般以月或者周为更新周期。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 239 - 393, 353)","boundsInScreen":"(0, 880 - 1080, 1193)"},{"index":5,"text":"3.为什么曾经获得的勋章“消失了”？","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 352 - 393, 400)","boundsInScreen":"(0, 1190 - 1080, 1322)"},{"index":6,"text":"获得勋章之后如果出现违规或不良行为行为（包括但不限于恶意刷粉丝、评价炒作、机器作弊等），勋章将会被回收。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 399 - 393, 491)","boundsInScreen":"(0, 1320 - 1080, 1573)"},{"index":7,"text":"4.其他注意事项","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 491 - 393, 539)","boundsInScreen":"(0, 1573 - 1080, 1705)"},{"index":8,"text":"1）闲鱼可根据实际情况对勋章的规则进行变动或调整，相关变动或调整将公布在我的勋章页面或者本说明页面上，公布后依法生效。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 538 - 393, 630)","boundsInScreen":"(0, 1702 - 1080, 1955)"},{"index":9,"text":"2）用户存在违规或不良行为（包括但不限于恶意刷粉丝、评价炒作、机器作弊等），闲鱼有权取消用户获得勋章的资格，并有权收回相应奖励，同时依照相关规则进行处罚。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 629 - 393, 743)","boundsInScreen":"(0, 1952 - 1080, 2266)"},{"index":10,"text":"3）如出现不可抗力或情势变更的情况（包括但不限于重大灾害事件、活动受政府机关指令需要停止举办或调整的、活动遭受严重网络攻击或系统故障需要暂停举办的），则闲鱼可依相关法律法规的规定主张免责。","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":true,"boundsInParent":"(0, 742 - 393, 792)","boundsInScreen":"(0, 2263 - 1080, 2400)"},{"index":11,"text":"","class":"android.view.View","package":"com.taobao.idlefish","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"isVisibleToUser":false,"boundsInParent":"(0, 791 - 393, 792)","boundsInScreen":"(0, 2398 - 1080, 2400)"}]}]}]}]}]}]}]}