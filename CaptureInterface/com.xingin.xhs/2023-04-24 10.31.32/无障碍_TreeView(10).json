":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 998, 782)","boundsInScreen":"(41, 258 - 1039, -114)"},{"index":3,"text":"04-13 上海","resource-id":"com.xingin.xhs:id\/eil","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 998, 35)","boundsInScreen":"(41, 258 - 1039, -37)"},{"index":4,"text":"共 17条评论","resource-id":"com.xingin.xhs:id\/eh1","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 189, 55)","boundsInScreen":"(41, 258 - 230, 115)"},{"index":5,"resource-id":"com.xingin.xhs:id\/bx","class":"android.widget.RelativeLayout","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 143)","boundsInScreen":"(0, 258 - 1080, 258)","children":[{"index":0,"text":"爱评论的人运气都不差~","resource-id":"com.xingin.xhs:id\/eh2","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 882, 89)","boundsInScreen":"(157, 258 - 1039, 231)"}]},{"index":6,"resource-id":"com.xingin.xhs:id\/ehp","class":"androidx.recyclerview.widget.RecyclerView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled