四月天 #深圳公园 #深圳龙岗拍照打卡 ","resource-id":"com.xingin.xhs:id\/chg","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 998, 1190)","boundsInScreen":"(41, 258 - 1039, 337)"},{"index":3,"text":"编辑于 04-18 广东","resource-id":"com.xingin.xhs:id\/eil","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 998, 35)","boundsInScreen":"(41, 379 - 1039, 414)"},{"index":4,"text":"共 10条评论","resource-id":"com.xingin.xhs:id\/eh1","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 189, 55)","boundsInScreen":"(41, 511 - 230, 566)"},{"index":5,"resource-id":"com.xingin.xhs:id\/bx","class":"android.widget.RelativeLayout","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 143)","boundsInScreen":"(0, 566 - 1080, 709)","children":[{"index":0,"text":"说点什么吧，万一火了呢~","resource-id":"com.xingin.xhs:id\/eh2","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 882, 89)","boundsInScreen":"(157, 593 - 1039, 682)"}]},{"index":6,"resource-id":"com.xingin.xhs:id\/ehp","class":"androidx.recyclerview.