rd":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 1440)","boundsInScreen":"(0, 258 - 1080, -3231)","children":[{"index":0,"resource-id":"com.xingin.xhs:id\/eto","class":"android.widget.ImageView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 1440)","boundsInScreen":"(0, 258 - 1080, -3231)"}]},{"index":1,"class":"android.widget.FrameLayout","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 1440)","boundsInScreen":"(1080, 258 - 1080, -3231)","children":[{"index":0,"resource-id":"com.xingin.xhs:id\/eto","class":"android.widget.ImageView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 1440)","boundsInScreen":"(1080, 258 - 1080, -3231)"}]}]},{"index":1,"text":"深圳10大必去日落观赏地|情侣约会好去处！","resource-id":"com.xingin.xhs:id\/eiy","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 998, 54)","boundsInScreen":"(41, 258 - 1039, -3093)"},{"index":2,"text":"1⃣️西湾红树林\n大海、礁石、黄昏、桥洞、电线塔、树林、飞机......集合了一切浪漫元素，在这里看一场日落，是视觉和精神的双重享受\n🎟️门票：免费\n🚇交通：地铁1号线到固戍站，换乘公交B887可达\n.\n2⃣️欢乐港湾摩天轮\n有着360°全景落地窗，建议在傍晚搭乘，登上128米的高空，可以远眺前湾、大铲湾和整个西部海岸线\n🎟️门票：128元\n🚇交通：地铁5号线临海站B2出口步行\n.\n3⃣️深圳湾公园\n在深圳湾公园看一场火烧云吧！高低错落的高楼灯火与自然相偎，时不时还有成群结伴的飞鸟经过\n🎟️门票：免费\n🚇交通：地铁9号线深圳湾公园站\n.\n4⃣️前海演艺公园\n这里聚集了摩天轮、日落、大海、椰树以及大片草地，没有高楼大厦的遮挡，宽阔的视野可以将美景尽收眼底\n🎟️门票：免费\n🚇交通：地铁5号线前海湾站E出口\n.\n5⃣️铁仔山公园\n山顶悬空的日落观景台，可将城市建筑与大海尽收眼底，还能远眺宝安机场与沿江大桥，是绝佳拍照机位\n🎟️门票：免费\n🚇交通：乘坐公交到凤凰智谷公交场站\n.\n6⃣️背仔角灯塔\n这里是盐田海滨栈道的起终点，一座灯塔伫立在海上，每到日落时分，晚霞倒影在海面上，美不胜收\n🎟️门票：免费\n🚇交通：乘坐公交到背仔角站\n.\n7⃣️梧桐山\n海拔943.7米，为深圳第一峰，夕阳西下时，登上梧桐山顶，绵延起伏的山峦、壮丽的落日和繁华的城市景观交织在一起\n🎟️门票：免费\n🚇交通：地铁2\/8号线梧桐山南站\n.\n8⃣️大南山\n在大南山能俯瞰整个南山半岛，能俯瞰港口，看到绝美日落和夜景，拍到深圳最壮观的城市天际线\n🎟️门票：免费\n🚇交通：荔林地铁口A出走盘山公路上山\n.\n9⃣️平安金融中心\n深圳第一高楼，是深圳市区看高空日落的最佳选择之一，547.6米的高空之上，城市景观尽收眼底\n🎟️门票：180元\n🚇交通：地铁1号线购物公园站D口\n.\n🔟蛇口渔人码头\n是深圳水产品的重要批发市场。渔船+灯塔的组合，夕阳把天际染成浅黄、橙黄、橙红、淡紫，美得惊人\n🎟️门票：免费\n🚇交通：地铁2号线东角头B口\n@薯队长 @生活薯 @走走薯 @城市情报官\n#深圳拍照 #深圳看海 #深圳旅行 #深圳周末做什么#小红书旅行月历 #海边日落 #情侣约会 ","resource-id":"com.xingin.xhs:id\/chg","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 998, 3961)","boundsInScreen":"(41, 258 - 1039, 896)"},{"index":3,"text":"04-14 广东","resource-id":"com.xingin.xhs:id\/eil","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 998, 35)","boundsInScreen":"(41, 938 - 1039, 973)"},{"index":4,"text":"共 3条评论","resource-id":"com.xingin.xhs:id\/eh1","class":"android.widget.TextView","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 171, 55)","boundsInScreen":"(41, 1070 - 212, 1125)"},{"index":5,"resource-id":"com.xingin.xhs:id\/bx","class":"android.widget.RelativeLayout","package":"com.xingin.xhs","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password"