le":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 2037)","boundsInScreen":"(0, 225 - 1080, 2262)","children":[{"index":0,"class":"androidx.recyclerview.widget.RecyclerView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":true,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 2037)","boundsInScreen":"(0, 225 - 1080, 2260)","children":[{"index":0,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 979)","boundsInScreen":"(33, 225 - 525, 899)","children":[{"index":0,"text":"「控卡」鸡肉薯片|高蛋白·非油炸·0蔗糖 | 作为一个不那么爱吃薯片、吃薯片大多只是因为好奇的人，看到这款声称含有鸡胸肉的薯片，对于薯片的那份好奇心又又又被撩起。除了本身就含有30%的鸡胸肉外，还～高蛋白、非油炸、0蔗糖......呵呵，就是不给人拒绝的理由是吧？！-它那个包装气鼓鼓的样子，看起来很骄傲嘛~三角形的薯片，有点点厚度，吃起来口感属于嘭嘭脆。买的是日式烤肉味，主要就是“烤“香，咸香浓郁，回口有淡淡的鲜香气。-因为“控卡薯片”是它的卖点，所以再提几笔它的营养成分。我买的这种，一包是30g。其中，蛋白质含量9.5g，每100g薯片的蛋白质含量才等于5个鸡蛋的蛋白含量。（我的贴心暗示，懂了吗？）一包薯片的能量 503 kJ，脂肪1.7g，碳水化合物16.4g，钠298mg，请参考。☆本想法纯属个人经历的快乐分享☆如感兴趣，辛苦使用带有外包装的图片自行在各软件中搜寻喔。 #手机里的今天# #啊，米饼小猴猴又吃零食了#","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 426, 108)","boundsInScreen":"(66, 603 - 492, 711)"},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 106)","boundsInScreen":"(33, 711 - 525, 817)","children":[{"index":0,"text":"米饼小猴猴","resource-id":"com.zhihu.android:id\/mPublishNameView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 165, 45)","boundsInScreen":"(127, 741 - 292, 786)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 130, 50)","boundsInScreen":"(395, 739 - 525, 789)","children":[{"index":0,"text":"26","resource-id":"com.zhihu.android:id\/mApplaudCountView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 39, 45)","boundsInScreen":"(453, 741 - 492, 786)"}]}]},{"index":2,"text":"啊，米饼小猴猴又吃零食了","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 357, 37)","boundsInScreen":"(77, 823 - 434, 860)"}]},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 979)","boundsInScreen":"(33, 932 - 525, 1911)","children":[{"index":0,"text":"✅讨厌一个人，不必撕破脸，用这6招狠狠反击👍谁都会有讨厌的人，谁会被人讨厌。如果因为讨厌的人影响到自己的情绪、甚至是决定，那就是对自己的消耗了❤️与其浪费时间讨厌别人，不如花时间狠狠取悦自己。1、不喜欢，请远离2、不争不辩，心平气和3、不动声色地远离4、努力变优秀5、不讨好，不在乎6、过好自己的生活🔆给大家分享一段我很喜欢的话：送给大家村上春树的一段话：“你要记得那些黑暗中默默抱紧你的人，逗你笑的人，陪你彻夜聊天的人，坐车来看望你的人，陪你哭过的人，在医院陪你的人，总是以你为重的人，带着你四处游荡的人，说想念你的人。”余生很贵，别浪费在讨厌的人身上，把讨厌别人的时间，用来记住喜欢的人，用来喜欢自己。愿你我这一生有被讨厌的勇气，也有被喜欢的实力。","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 426, 108)","boundsInScreen":"(66, 1615 - 492, 1723)"},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 106)","boundsInScreen":"(33, 1723 - 525, 1829)","children":[{"index":0,"text":"浅浅同学","resource-id":"com.zhihu.android:id\/mPublishNameView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 132, 45)","boundsInScreen":"(127, 1753 - 259, 1798)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 145, 50)","boundsInScreen":"(380, 1751 - 525, 1801)","children":[{"index":0,"text":"377","resource-id":"com.zhihu.android:id\/mApplaudCountView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 54, 45)","boundsInScreen":"(438, 1753 - 492, 1798)"}]}]},{"index":2,"text":"悦享生活课代表","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 222, 37)","boundsInScreen":"(77, 1835 - 299, 1872)"}]},{"index":2,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 979)","boundsInScreen":"(555, 225 - 1047, 984)","children":[{"index":0,"text":"不同人适合用什么手机，你是哪一款? | 不知道大家周围的人都用什么手机呢？我身边的人用的基本都是苹果手机，少数人用的是红米，可能因为都是年轻打工人，都比较喜欢性价比高，耐用又省钱的。1.打工人追求高性价比，系统流畅2.学生党预算不高，追求性价比，配置均衡，游戏和拍照都不错3.上流人士高端且有面子，高品质，有质感4.游戏党打游戏流畅，8P现在还有很多游戏主播在用，游戏体验确实舒适，就是只有二手机了，适合当备用机使用5.明星网红必须是用苹果，拍照和拍视频都很优秀6.外卖小哥续航强，信号稳定，质量好抗摔7.父母长辈屏幕护眼，大屏大字，续航久，广告少8.摄影爱好者影像能力强的，有很多优秀的影像旗舰都很不错#苹果产品# #小米手机# #华为# #红米手机# #手机# #手机游戏# #手机摄影# #数码#","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 426, 108)","boundsInScreen":"(588, 688 - 1014, 796)"},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"bounds