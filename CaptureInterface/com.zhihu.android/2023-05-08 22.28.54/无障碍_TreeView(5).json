:false,"boundsInParent":"(0, 0 - 165, 45)","boundsInScreen":"(127, 410 - 292, 455)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 150, 50)","boundsInScreen":"(375, 408 - 525, 458)","children":[{"index":0,"text":"694","resource-id":"com.zhihu.android:id\/mApplaudCountView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 59, 45)","boundsInScreen":"(433, 410 - 492, 455)"}]}]},{"index":2,"text":"心理学","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 114, 37)","boundsInScreen":"(77, 492 - 191, 529)"},{"index":3,"text":"想法打卡挑战赛第5期","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 252, 37)","boundsInScreen":"(229, 492 - 481, 529)"}]},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 979)","boundsInScreen":"(33, 601 - 525, 1580)","children":[{"index":0,"text":"消失的风景：毁于大火的大安寨荆花湾宅院 | 几乎算是位于自贡市区最高点的大安寨是1850年太平天国革命爆发后，本地大盐商们为了保护家族财产，集资修建的寨堡另一个著名的寨堡是同样位于大安区的「三多寨」.大安寨是咸丰十年（1860）年，由富顺知县胡汝开提出，四大盐商之一，「王三畏堂」的发家人王朗云召集其他几家修建的位置在如今大安区龙井街和大社区王大山山顶，省盐校也在山上.建成次年1861年，数万农民军在大安寨对面的山上设中营扎营相对，后来这里被本地居民称为「中营山」，时至今日，地名被讹传为「钟云山」，是上世纪末期，自贡市区统一规划建设的住宅小区.大安寨内，目前还保留着不少晚清到民国时间的民宅建筑：包括王三畏堂的总柜房，芝兰堂、上下天心窝宅院（图5⃣️-8⃣️）很可惜的是，建于1913年的荆花湾宅院，在2022年一场大火中毁掉（图1⃣️-4⃣️）所幸21年春节去拍下了这些照片，以后再无这样的景致，不知图上那只小丑猫，有没有从这场火灾里逃生？.▫️▫️▫️实用信息▫️▫️▫️🚌：305路终点站省盐校站，下车即可🚶🏻‍♀️：可从洞口井沿山而上，能看到自贡世界地质公园里「大坟堡粘土」地层命名地（图9⃣️）和若干地层标识，建议地质爱好者徒步上山（不陡）.熟知来路，方识去处.一个人，如果很清楚自己家庭的历史，自己家乡的掌故，那么在面对未知和未来的时候，也许会多一些勇气和淡然。想成为这样的人。.更多自贡历史和人文，欢迎🌟>>> #灯下说自贡# .本篇历史考据内容，参考自已故盐史专家宋良曦先生文章#我最爱的城市一角# #100个知乎答主的周末# #玩过周末#","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 426, 108)","boundsInScreen":"(66, 1284 - 492, 1392)"},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 106)","boundsInScreen":"(33, 1392 - 525, 1498)","children":[{"index":0,"text":"灯下说书人","resource-id":"com.zhihu.android:id\/mPublishNameView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 165, 45)","boundsInScreen":"(127, 1422 - 292, 1467)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":t