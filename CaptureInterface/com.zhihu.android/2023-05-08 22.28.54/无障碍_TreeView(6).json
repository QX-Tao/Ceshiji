se,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 168, 45)","boundsInScreen":"(127, 656 - 295, 701)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 132, 50)","boundsInScreen":"(393, 654 - 525, 704)","children":[{"index":0,"text":"83","resource-id":"com.zhihu.android:id\/mApplaudCountView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 41, 45)","boundsInScreen":"(451, 656 - 492, 701)"}]}]},{"index":2,"text":"遇见艺术","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 141, 37)","boundsInScreen":"(77, 738 - 218, 775)"},{"index":3,"text":"艺术","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 87, 37)","boundsInScreen":"(256, 738 - 343, 775)"}]},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 897)","boundsInScreen":"(555, 225 - 1047, 217)","children":[{"index":0,"text":"一看就懂!你真的知道怎么买黄金吗? | 就这1篇笔记，你就能看懂如何选择黄金，再也不用担心买不好黄金啦~*超强黄金科普&避坑攻略[黄金首饰]黄金首饰常用的标注为“足金”，代表纯度含量不少于99%的黄金，千足金(含量99.90%)、万足金(含量99.99%)都在此列。除了“足金”标识之外，还有“Au990”、、“G990”、“GOLD9999”等[k金]k金是按照黄金的纯度而划分的，k金分为1k~24k24K的含量是99%以上的黄金;18K的含量是75%以上:14K的含量是58%以上;10K的含量是41%以上18k首饰钢印的印记通常为“18K”、“Au750”[铂金]“足铂”、“铂ggo”和“Pt990”的标识用于纯度含量不少于99.00%的铂金首饰，其他纯度的铂金使用铂金符号加纯度的标记，例如:“铂950”“Pt950”“铂900”等[钯金]钯金首饰的印记一般用Pd表示，常用标识“Pd999”“Pd990”“Pd950”[白银]足银:标记直接为“足银”或按实际含量打标记。指的是首饰中含银量不少于99%925银:标记为“银925”或“S925”。指的是首饰中含银量不小于92.5%925银:标记为“银925”或“S925”。指的是首饰中含银量不小于92.5%[镀金]利用电解原理在银或铜制成的首饰表面上镀上层极薄的黄金，我国行业标准镀金层厚不小于0.5um，镀金层首饰的标记为“Gp”或“Kp”","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 426, 108)","boundsInScreen":"(588, 225 - 1014, 111)"},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 106)","boundsInScreen":"(555, 225 - 1047, 217)","children":[{"index":0,"text":"Eliauk","resource-id":"com.zhihu.android:id\/mPublishNameView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 90, 45)","boundsInScreen":"(649, 225 - 739, 186)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 146, 50)","boundsInScreen":"(901, 225 - 1047, 189)","children":[{"index":0,"text":"108","resource-id":"com.zhihu.android:id\/mApplaudCountView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 55, 45)","boundsInScreen":"(959, 225 - 1014, 186)"}]}]}]},{"index":2,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 492, 821)","boundsInScreen":"(33, 847 - 525, 1668)","children":[{"index":0,"text":"趁打折入手了一款克苏鲁题材游戏《海岸》（The Shore），讲实话打完还蛮吃惊的，因为这游戏简直可以称得上是「洛氏宇宙神明 3D 图鉴」了。游戏围绕「痛失爱女的水手父亲为了拯救女儿，流落孤岛后听从不知名神祇的指引完成秘仪」的故事，在一部作品内就向玩家展现了一系列克苏鲁神话中的知名邪神以及眷属种族，包括但不限于：大衮、深潜者、克苏鲁、奈亚拉托提普、莎布 · 尼古拉丝、黑山羊幼仔、优格 · 索托斯……甚至最后的结局是主角亲自觐见至高神阿撒托斯。除此之外，游戏也配合这些邪神设计了一些诡异震撼的遗迹场景与黑暗恶心的异星世界。如果你对克氏神话兴趣浓厚的话，那这个游戏肯定能让你好好满足一下。不过嘛，这部作品在游戏性方面的确不敢恭维，只有小品级的体量（约 2~3 小时流程）但关卡设计还是肉眼可见的糙，缺乏指引的解密以及存在大量奇怪空气墙的地图使游玩体验很难称得上舒适。并且游戏中也未给登场的神明与眷属附加任何背景解释 Tips，不了解克苏鲁神话的玩家大概率会玩得云里雾里，因此整体上属于粉丝向性质比较浓厚的作品，算不得精美。当然缺点归缺点，一下给这么多克系神设计了 3D 造型，以图像形式还原了原著中纯靠文字描写的掉 SAN 场景与巨物恐惧形象，让玩家能够「身临其境」地目睹洛夫克拉夫特笔下那群难以名状、超越常识的外星神明现身，做到这一点的本作已经具有了优秀的价值。特别是在目前市面上纯克系题材 3D 游戏作品本就屈指可数的情况下，这部《海岸》就更是值得推荐了。PS：配乐也还可以，比较契合氛围，并且有官中（但是机翻）。主要是打折才￥8，还要啥自行车嘛[调皮]#游戏# #克苏鲁 (Cthulhu)# #想法打卡挑战赛第5期#","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 