ue,"focusable":true,"focused":false,"scrollable":false,"long-clickable":true,"password":false,"selected":false,"boundsInParent":"(0, 0 - 1080, 2341)","boundsInScreen":"(0, 380 - 1080, 2268)","children":[{"index":0,"resource-id":"com.zhihu.android:id\/avatar","class":"android.widget.ImageView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 82, 82)","boundsInScreen":"(55, 380 - 137, 275)"},{"index":1,"text":"一只真心的汤包","resource-id":"com.zhihu.android:id\/name","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 266, 51)","boundsInScreen":"(165, 380 - 431, 246)"},{"index":2,"resource-id":"com.zhihu.android:id\/more","class":"android.widget.ImageView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 55, 55)","boundsInScreen":"(970, 380 - 1025, 248)"},{"index":3,"text":"B站确实有些变味了，弹幕开玩笑没有底线。一边嘲讽饭圈，一边推崇yygq，也不知道怎么回事，唉。Up主本身更该与时俱进，提高自己视频的质量，说实话蕾丝翔翔大作战那些视频我实在get不到观赏性的点在哪儿。而且视频本身质量其实并不高，无非拆箱做一些博人眼球的几百份食材试吃制作之类的，而且那些视频剪辑有时候我觉得过于嘈杂，看得头痛。而且基基视频我以前很喜欢，但是后来我发现他有点喜欢ghs，而且次数频繁就取关了，经常视频会恰饭，次数太多了些。坦白说，B站像何同学那种真心实意喜欢科技数码产品并拍视频的真的很少，大部分也许最初想拍视频为爱好，现在都是追逐名利了。","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"boundsInParent":"(0, 0 - 860, 877)","boundsInScreen":"(165, 380 - 1025, 1139)"},{"index":4,"text":"2020-04-23","resource-id":