g-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 231, 45)","boundsInScreen":"(127, 1838 - 358, 1883)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 143, 50)","boundsInScreen":"(382, 1836 - 525, 1886)","children":[{"index":0,"text":"125","resource-id":"com.zhihu.android:id\/mApplaudCountView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 52, 45)","boundsInScreen":"(440, 1838 - 492, 1883)"}]}]},{"index":2,"text":"想法打卡挑战赛第6期","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 292, 37)","boundsInScreen":"(77, 1920 - 369, 1957)"}]},{"index":3,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 492, 979)","boundsInScreen":"(555, 772 - 1047, 1751)","children":[{"index":0,"text":"中国各省份的海拔 | 其实这些数据可能很多人都清楚，但是如果不把它们放在同一张图上，可能大家很难有个直观的感受，到底每个省份海拔有多高。画完之后我也发现有一部分比较反直觉的地方，比如第一印象里以平原为主的沿海省份河北，因为有太行山和燕山的缘故，最高海拔居然超过了深居内陆的湖南。四川的川西也有很多高山，让四川的最高海拔超过了青海。另外，和青藏高原不沾边的省份里海拔最高的居然是海里的台湾。上海和澳门的天然海拔最高点，甚至还赶不上它们各自最高的建筑。各省海拔和世界上的一些高山对比，可以发现澳洲大陆是真的平，连一座能打的山峰都没有，最高峰还比不过河南，而大洋洲最高峰在新几内亚岛上。紫色那几条线标出的是不同定义下的世界最高峰。珠峰当然不必多说了，是绝对海拔最高的。南美洲的钦博拉佐山虽然在绝对海拔上连南美第一都没抢到，但因为它靠近赤道，空间高度（山顶到地心的距离）却比珠峰多了那么一点点。另外还有就是相对海拔了，也就是山顶到山脚的距离。珠峰山脚的海拔也不低，北坡大本营都有五千多米。要论山顶到山脚的高差谁最大，有两种说法，如果只算海平面以上的，就是北美最高峰麦金利山，如果连海面以下都算是，那就是夏威夷的冒纳罗亚火山了。 #一图读懂# #每日知识图#","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 426, 108)","boundsInScreen":"(588, 1455 - 1014, 1563)"},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 492, 106)","boundsInScreen":"(555, 1563 - 1047, 1669)","children":[{"index":0,"text":"叶山Shan Ye","resource-id":"com.zhihu.android:id\/mPublishNameView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 187, 45)","boundsInScreen":"(649, 1593 - 836, 1638)"},{"index":1,"resource-id":"com.zhihu.android:id\/mApplaudLayout","class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 151, 50)","boundsInScreen":"(896, 1591 - 1047, 1641)","children":[{"index":0,"text":"349","resource-id":"com.zhihu.android:id\/mApplaudCountView","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 60, 45)","boundsInScreen":"(954, 1593 - 1014, 1638)"}]}]},{"index":2,"text":"想法精选","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 108, 37)","boundsInScreen":"(599, 1675 - 707, 1712)"}]},{"index":4,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 492, 897)","boundsInScreen":"(33, 2029 - 525, 2260)","children":[{"index":0,"text":"kiss a robot | 随着科技的不断进步，人类与机器人之间的互动方式也将发生深刻的变化。在不久的将来，我们或许可以预见到以下几个方面的发展：1. 情感交流的深度提升：未来的机器人将具备更强大的情感识别和表达能力，能够更好地理解人类的需求和情感，并作出相应的回应。2. 个性化定制：随着人工智能技术的进一步发展，机器人将可以根据个人喜好和需求进行个性化定制，从而为每个人提供独一无二的服务。3. 人机共生：未来，机器人将成为人类生活中不可或缺的一部分，与人类共同构建一个更加美好的世界。例如，在家庭中，机器人可以担任更多家务劳动的角色，让人们有更多时间去享受生活。4. 伦理道德的讨论：随着机器人接吻等亲密行为的普及，伦理道德问题也逐渐浮出水面。我们需要对这些问题进行深入探讨，以确保科技的发展不会侵犯人类的尊严和权益。机器人之吻是科技与浪漫的完美融合，它为我们带来了前所未有的体验和感受。在未来的发展过程中，人类与机器人之间的关系将变得更加紧密，我们将共同探索这个充满无限可能的世界。","resource-id":"com.zhihu.android:id\/content","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 426, 108)","boundsInScreen":"(66, 2712 - 492, 2260)"},{"index":1,"class":"androidx.appcompat.widget.LinearLayoutCompat","package":"com.zhih