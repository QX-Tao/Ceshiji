rd":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 2037)","boundsInScreen":"(0, 225 - 1080, 2262)","children":[{"index":0,"class":"androidx.recyclerview.widget.RecyclerView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":true,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 2037)","boundsInScreen":"(0, 225 - 1080, 2260)","children":[{"index":0,"class":"android.view.ViewGroup","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 413)","boundsInScreen":"(0, 225 - 1080, 477)","children":[{"index":0,"text":"硫磺皂的功效是什么？","resource-id":"com.zhihu.android:id\/everyone_watching_title","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 992, 55)","boundsInScreen":"(44, 225 - 1036, 158)"},{"index":1,"text":"APP真我: 硫磺皂这种老牌产品，应该有不少人小时候都用过吧。 小真小时候也用过，以前青春期的时候，背上总是长很多痘痘粉刺，麻麻就买了 硫磺皂 回来。在大部分人的概念里，硫磺皂的主要功效就是控油祛痘，用来洗澡特别合适。 [图片] 那它为什么承担了这种功效呢？ 1.肥皂中加入了硫磺，使用的时候会产生硫化氢 和五氯磺酸 ，可以达到杀菌的效果。 2.痘痘肌肤一般呈油性偏酸，而硫磺皂中的硫磺呈碱性，可以中和酸性肌肤，达到控油、杀死细菌、防治细…","resource-id":"com.zhihu.android:id\/everyone_watching_desc","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 722, 156)","boundsInScreen":"(44, 225 - 766, 336)"},{"index":2,"text":"等 18 人赞同","resource-id":"com.zhihu.android:id\/follow_user_action_text","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 202, 48)","boundsInScreen":"(162, 378 - 364, 426)"}]},{"index":1,"class":"android.view.ViewGroup","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 413)","boundsInScreen":"(0, 477 - 1080, 890)","children":[{"index":0,"text":"长期抹维生素e乳能变白吗?","resource-id":"com.zhihu.android:id\/everyone_watching_title","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 992, 55)","boundsInScreen":"(44, 516 - 1036, 571)"},{"index":1,"text":"APP真我: 怎么说呢？ “维E乳”说白了，就是添加了维生素E的乳状产品，可以是乳霜也可以是乳液。按照最先火爆的标婷维E来说，大家对它的评价是使用感滋润保湿，软化角质，防止干裂脱皮，可以抚平肌肤粗糙，使触感柔软细嫩。 [图片] 安全温和，任何肌肤都能使用，可做面部基础护理，也可以作为身体乳！ 实际上，维生素E的作用，主要是抗氧化美白。 [图片] 大部分护肤品都是靠维生素E这个成分，来增加产品抵抗衰老，抚平细纹的作用。 相比于维生素E，维E的…","resource-id":"com.zhihu.android:id\/everyone_watching_desc","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 722, 156)","boundsInScreen":"(44, 593 - 766, 749)"},{"index":2,"text":"等 75 人赞同","resource-id":"com.zhihu.android:id\/follow_user_action_text","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 205, 48)","boundsInScreen":"(200, 791 - 405, 839)"}]},{"index":2,"class":"android.view.ViewGroup","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 413)","boundsInScreen":"(0, 890 - 1080, 1303)","children":[{"index":0,"text":"什么牌子的一次性洗脸巾比较好","resource-id":"com.zhihu.android:id\/everyone_watching_title","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 992, 55)","boundsInScreen":"(44, 929 - 1036, 984)"},{"index":1,"text":"APP真我: 这必须得提出我无限回购的宝藏洗脸巾了！ [图片] 很多人都把一些新型产品当做 智商税 ，但其实这种东西是针对于个人需求来说的。怎么讲呢，你有这种需要，你就觉得他是有必要的。如果你对这方面不是很注重，那对你来说就是不必要的。 小编是根据护肤的立场来分析，就护肤的安全性来说，我认为大家是有必要使用洗脸巾了进行清洁的。 [图片] 大家都知道，清洁是护肤的基础，也是必不可缺少的一步。只有保持肌肤的清爽洁净，才能更好的进行后续护肤…","resource-id":"com.zhihu.android:id\/everyone_watching_desc","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 722, 156)","boundsInScreen":"(44, 1006 - 766, 1162)"},{"index":2,"text":"等 63 人赞同","resource-id":"com.zhihu.android:id\/follow_user_action_text","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 207, 48)","boundsInScreen":"(200, 1204 - 407, 1252)"}]},{"index":3,"class":"android.view.ViewGroup","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 413)","boundsInScreen":"(0, 1303 - 1080, 1716)","children":[{"index":0,"text":"戴口罩的你还化妆吗？","resource-id":"com.zhihu.android:id\/everyone_watching_title","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 992, 55)","boundsInScreen":"(44, 1342 - 1036, 1397)"},{"index":1,"text":"真我APP: 口罩一直在戴，妆一直很少化，相信很多宝宝和我一样，觉得化了也是白化，连自己都看不到哇，哈哈，不过很爱美的宝宝也可以化个眼妆吧。不管是不是化妆，护肤工作还是要坚持去做的，有一个好的肌肤底子，素颜很清爽，化妆的话，会更服帖。想要拥有一个好的肌肤底子，离不开日积月累的护肤，而护肤也有很多讲究，是否懂得科学护肤，直接关系到护肤的成效。 小编在遇到真我APP之前，护肤品都是到处听推荐，后来便慢慢学会了科学护肤…","resource-id":"com.zhihu.android:id\/everyone_watching_desc","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 722, 156)","boundsInScreen":"(44, 1419 - 766, 1575)"},{"index":2,"text":"等 26 人赞同","resource-id":"com.zhihu.android:id\/follow_user_action_text","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 206, 48)","boundsInScreen":"(162, 1617 - 368, 1665)"}]},{"index":4,"class":"android.view.ViewGroup","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 413)","boundsInScreen":"(0, 1716 - 1080, 2129)","children":[{"index":0,"text":"网上那些不是很知名，却很好用的洗发水有哪些？","resource-id":"com.zhihu.android:id\/everyone_watching_title","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 992, 55)","boundsInScreen":"(44, 1755 - 1036, 1810)"},{"index":1,"text":"APP真我: 洗发水这种产品，地位和牙膏一样！ 虽然必不可缺，但却很少有人去认真挑选。 [图片] 大家对于护肤品的了解非常广泛，要问你怎么选择也能说的头头是道。但要让你说说怎么什么是适合的洗发水，却很少有人能解释清楚。 为什么？ 因为觉得洗发水不重要，这也是很多人护理不好自己的头发的关键原因。小编见过很多人，买各种的护发精油、发膜、 蒸发帽 等一系列产品搭配使用，却依然用着网上、超市里面随手买回来的洗护套装 。殊不知，一瓶适合…","resource-id":"com.zhihu.android:id\/everyone_watching_desc","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 722, 156)","boundsInScreen":"(44, 1832 - 766, 1988)"},{"index":2,"text":"等 33 人赞同","resource-id":"com.zhihu.android:id\/follow_user_action_text","class":"android.widget.TextView","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 206, 48)","boundsInScreen":"(162, 2030 - 368, 2078)"}]},{"index":5,"class":"android.view.ViewGroup","package":"com.zhihu.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected"