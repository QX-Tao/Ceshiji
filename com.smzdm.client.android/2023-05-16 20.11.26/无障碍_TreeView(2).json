InParent":"(0, 0 - 765, 52)","boundsInScreen":"(179, 2531 - 944, 2400)"},{"index":1,"text":"05-14","resource-id":"com.smzdm.client.android:id\/tv_time","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 95, 49)","boundsInScreen":"(944, 2534 - 1039, 2400)"},{"index":2,"text":"发布了晒物","resource-id":"com.smzdm.client.android:id\/tv_title","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 180, 49)","boundsInScreen":"(179, 2600 - 359, 2400)"},{"index":3,"resource-id":"com.smzdm.client.android:id\/cv_layout","class":"android.widget.FrameLayout","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 844, 702)","boundsInScreen":"(187, 2712 - 1031, 2400)","children":[{"index":0,"text":"舍友立下flag说：如果我能和他一起骑行到首钢桥，且能拉爆他，就给我买闪电的S-works。不信邪的我决定应战，陪他骑一圈。昨天参加完值友嘉年华，晚上八点多拖着疲惫的身躯骑上了车。结果刚打开手表的骑行，便收到电量不足10%的提示。出师不利🤦‍♀️不过，我的腿力真的很强，在历时2小时48分钟，骑行55+公里，耗光了大疆Osmo和手表的电量后，我们终于到达了北京的最西边——首钢桥处。感觉S-works在向我招手👋🚴骑行装备：捷安特liv头盔捷安特自行车Monton骑行服+裤子Lululemon-ebb运动背心阿迪达斯 Stan smith板鞋今日听劝有戴头盔，建议大家骑行还是尽量佩戴头盔，不然危险系数很高。自行车和骑行服之前都有分享过，在此不赘述。不过可能由于骑行太久，骑行裤下面的屁垫效果已经没有了，骑到最后半程屁股也疼、腰也疼，很是辛苦。（想问大家长距离骑行都是靠什么缓解疼痛的）鞋子是2018年参加活动入的Stan smith板鞋。自从上次穿平底板鞋骑行时感受到板鞋更好发力后，现在每次骑行我都更倾向于穿板鞋。🚴写在最后：京城骑行的朋友们，要不要一起搞个值得买专属骑行小组，相约一起骑行～","resource-id":"com.smzdm.client.android:id\/tv_content","class":"android.widget.TextView","package":"com.smzdm.client.android","checkabl