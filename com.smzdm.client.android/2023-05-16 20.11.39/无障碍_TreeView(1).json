ckable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 844, 702)","boundsInScreen":"(187, 1041 - 1031, 1743)","children":[{"index":0,"text":"舍友立下flag说：如果我能和他一起骑行到首钢桥，且能拉爆他，就给我买闪电的S-works。不信邪的我决定应战，陪他骑一圈。昨天参加完值友嘉年华，晚上八点多拖着疲惫的身躯骑上了车。结果刚打开手表的骑行，便收到电量不足10%的提示。出师不利🤦‍♀️不过，我的腿力真的很强，在历时2小时48分钟，骑行55+公里，耗光了大疆Osmo和手表的电量后，我们终于到达了北京的最西边——首钢桥处。感觉S-works在向我招手👋🚴骑行装备：捷安特liv头盔捷安特自行车Monton骑行服+裤子Lululemon-ebb运动背心阿迪达斯 Stan smith板鞋今日听劝有戴头盔，建议大家骑行还是尽量佩戴头盔，不然危险系数很高。自行车和骑行服之前都有分享过，在此不赘述。不过可能由于骑行太久，骑行裤下面的屁垫效果已经没有了，骑到最后半程屁股也疼、腰也疼，很是辛苦。（想问大家长距离骑行都是靠什么缓解疼痛的）鞋子是2018年参加活动入的Stan smith板鞋。自从上次穿平底板鞋骑行时感受到板鞋更好发力后，现在每次骑行我都更倾向于穿板鞋。🚴写在最后：京城骑行的朋友们，要不要一起搞个值得买专属骑行小组，相约一起骑行～","resource-id":"com.smzdm.client.android:id\/tv_content","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 788, 297)","boundsInScreen":"(215, 1069 - 1003, 1366)"},{"index":1,"text":"10","resource-id":"com.smzdm.client.android:id\/imgNum","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 49, 55)","boundsInScreen":"(969, 1677 - 1018, 1732)"}]}]},{"index":2,"class":"android.widget.LinearLayout","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 999)","boundsInScreen":"(0, 1848 - 1080, 2400)","children":[{"index":0,"text":"大脸萌酱","resource-id":"com.smzdm.client.android:id\/tv_name","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 765, 52)","boundsInScreen":"(179, 1887 - 944, 1939)"},{"index":1,"text":"05-14","resource-id":"com.smzdm.client.android:id\/tv_time","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 95, 49)","boundsInScreen":"(944, 1890 - 1039, 1939)"},{"index":2,"text":"发布了晒物","resource-id":"com.smzdm.client.android:id\/tv_title","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 180, 49)","boundsInScreen":"(179, 1956 - 359, 2005)"},{"index":3,"resource-id":"com.smzdm.client.android:id\/cv_layout","class":"android.widget.FrameLayout","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 844, 702)","boundsInScreen":"(187, 2068 - 1031, 2400)","children":[{"index":0,"text":"为了参加今天值得买举办的消费嘉年华活动，不被值友发现本人真人与照片不符，萌酱一大早起床沐浴洗头，烫了个优雅的大波浪。衣服也是在众多件中挑选出的最显身材且看不出腿粗的“战袍”。现场见到了很多大佬，也被好几个值友认出来了（说明真人和照片差别不大）开心🥳，希望值得买多多举办这样的活动！今日穿搭：🌟连衣裙是去年买的Cos款，今天去逛街，发现Cos今年原封不动复制了去年的款式。果然经典的剪裁就是不容易过时。这件连衣裙很适合偏正式的场合穿着，也很显气质和身材。🌟为了显得身高不拉胯，今天穿了和连衣裙颜色很契合的高跟鞋。（之前介绍过了，暂不赘述）🌟今天的头发是用lena自动卷发棒卷的，为了定型，还喷了新买的定型喷雾。定型喷雾上头不会泛油光，定型一整天不是问题。写在最后：今天晒物任务完成，本人还在夜骑50km的进程中，大家明天见～","resource-id":"com.smzdm.client.android:id\/tv_content","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 788, 297)","boundsInScreen":"(215, 2096 - 1003, 2393)"},{"index":1,"text":"9","resource-id":"com.smzdm.client.android:id\/imgNum","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 31, 55)","boundsInScreen":"(978, 2704 - 1009, 2400)"}]}]}]},{"index":1,"resource-id":"com.smzdm.client.android:id\/list","class":"androidx.recyclerview.widget.RecyclerView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 1080, 1988)","boundsInScreen":"(1080, 412 - 1080, 2400)"},{"index":2,"text":"这里什么都没有，去看看别的","resource-id":"com.smzdm.client.android:id\/coupon_mine_nodata_lab","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 507, 52)","boundsInScreen":"(1366, 1759 - 1080, 1811)"}]}]}