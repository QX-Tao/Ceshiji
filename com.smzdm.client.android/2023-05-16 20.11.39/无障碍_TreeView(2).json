android:id\/cv_layout","class":"android.widget.FrameLayout","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 844, 702)","boundsInScreen":"(187, 1327 - 1031, 2029)","children":[{"index":0,"text":"律师衣橱里必不可少的单品，一定是衬衫。相比于男性衬衫款式和颜色的局限性，女性的衬衫，不仅版型很丰富，而且颜色也更多。像我现在拥有的衬衫，颜色比彩虹的配色还要丰富。夏天不知道穿什么时，我通常会用衬衫搭配半裙。主打的就是稳妥和不出错。尤其是过膝半裙，对腿粗梨形身材的妹子非常友好。衬衫：Massimo Dutti 衬衫半裙：东兮百褶半身裙高跟鞋：真美诗羊皮绒面高跟鞋包包：三宅一生包包项链：周生生羽毛吊坠","resource-id":"com.smzdm.client.android:id\/tv_content","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 788, 297)","boundsInScreen":"(215, 1355 - 1003, 1652)"},{"index":1,"text":"6","resource-id":"com.smzdm.client.android:id\/imgNum","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 32, 55)","boundsInScreen":"(978, 1963 - 1010, 2018)"}]}]},{"index":2,"class":"android.widget.LinearLayout","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 1080, 999)","boundsInScreen":"(0, 2134 - 1080, 2400)","children":[{"index":0,"text":"大脸萌酱","resource-id":"com.smzdm.client.android:id\/tv_name","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 759, 52)","boundsInScreen":"(179, 2173 - 938, 2225)"},{"index":1,"text":"05-07","resource-id":"com.smzdm.client.android:id\/tv_time","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 101, 49)","boundsInScreen":"(938, 2176 - 1039, 2225)"},{"index":2,"text":"发布了晒物","resource-id":"com.smzdm.client.android:id\/tv_title","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 180, 49)","boundsInScreen":"(179, 2242 - 359, 2291)"},{"index":3,"resource-id":"com.smzdm.client.android:id\/cv_layout","class":"android.widget.FrameLayout","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 844, 702)","boundsInScreen":"(187, 2354 - 1031, 2400)","children":[{"index":0,"text":"登登登登，穿搭博主再次上线！今年的五四青年节，萌酱第一次做主持人。这次的主持活动对我来说，荣幸且意义非凡。以前只是仰望别人在舞台上展现自我，自己却总是畏首畏尾不敢表现。等真正推自己一把站到台上时，竟然也能鼓起勇气发声，顺利的把流程走完。为已不是青年的我的进步而感到高兴！希望以后的每一次选择，都有勇气向前一步。关于穿搭：1.西服：theory西服套装2.高跟鞋：RV Trompette高跟鞋3.耳环：apm珍珠耳环4.手表：Garmin Venu 2plusTheory这套西服还是之前skp店庆时买的。一直没有机会穿出门，这次五四青年节活动，它终于派上了用场。浅粉色西服自带温柔优雅的职业气质，很适合职场女性穿着。西服羊毛含量96%，质感满分，且比较亲肤。Theory家的西服的版型是最值得一夸的，这套上身不仅修饰了腰身，而且也显得整体比例很好。.鞋子之前介绍过，是RV的高跟鞋，由于它的价格比较贵，所以买了也一直没舍得穿。趁着主持活动，才第一次穿它出门。它上脚脚感不错，穿它站了一天，虽然累，但是脚没有被磨破，各位职场女性可以考虑入手。.耳环是三四年前在唯品会上面买的，到手价538，接近原价4折。虽然已经戴了三四年，但它的光泽感一直如初，款式也不过时，珍珠微带光泽，佩戴后很显温柔气质。.手表是前年买的Garmin，续航持久，Venu系列也很适合职场人士佩戴。本片晒物到此结束，这是你理想中女律师的形象吗？","resource-id":"com.smzdm.client.android:id\/tv_content","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 788, 297)","boundsInScreen":"(215, 2382 - 1003, 2400)"},{"index":1,"text":"9","resource-id":"com.smzdm.client.android:id\/imgNum","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 31, 55)","boundsInScreen":"(978, 2990 - 1009, 2400)"}]}]}]},{"index":1,"resource-id":"com.smzdm.client.android:id\/list","class":"androidx.recyclerview.widget.RecyclerView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 1080, 1988)","boundsInScreen":"(1080, 412 - 1080, 2400)"},{"index":2,"text":"这里什么都没有，去看看别的","resource-id":"com.smzdm.client.android:id\/coupon_mine_nodata_lab","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 507, 52)","boundsInScreen":"(1366, 1759 - 1080, 1811)"}]}]}