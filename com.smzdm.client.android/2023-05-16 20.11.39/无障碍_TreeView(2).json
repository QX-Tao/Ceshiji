ed":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 94, 49)","boundsInScreen":"(945, 412 - 1039, 171)"},{"index":2,"text":"发布了晒物","resource-id":"com.smzdm.client.android:id\/tv_title","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":false,"boundsInParent":"(0, 0 - 180, 49)","boundsInScreen":"(179, 412 - 359, 237)"},{"index":3,"resource-id":"com.smzdm.client.android:id\/cv_layout","class":"android.widget.FrameLayout","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":true,"enabled":true,"focusable":true,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 844, 702)","boundsInScreen":"(187, 412 - 1031, 1002)","children":[{"index":0,"text":"京城最适合夜骑的路线，当属长安街了。马路宽敞，路灯又亮，基本每个路口都有戍守的👮，安全系数高，途中还能经过天安门，夜景超美。骑行在长安街上，感受夏天的风，轻轻吹过，流汗都是一种极致的享受。骑行装备：自行车：giant rincon2眼镜：欧克利运动太阳镜骑行服：Monton骑行服鞋子：梅森马吉拉德训鞋🎈夏天飞虫比较多，晚上骑行，最好还是佩戴骑行眼镜，防止飞虫飞入眼镜。这款眼镜是给舍友买的，昨晚骑行我借用的。它遇光会变墨镜，平时是透明色。虽然是男款，但我佩戴后也太容易滑落，很适配骑行。🎈骑行服是舍友给我买的，Monton是个国产做骑行服的牌子。上衣图案设计很可爱，衣服也很透气，骑行时不容易闷汗。后背有三个口袋，可以放手机和水瓶，能够在骑行时解放双手。裤子带有屁垫，长时间骑行不会屁股疼。它家衣服尺码有点偏小，买的时候要谨慎选号。🎈鞋子是前段时间买的德训鞋，鞋底薄且比较平，很适合蹬自行车，发力很便捷。写在最后：想要拿到618的晒物大奖，所以接下来一段时间要频繁发文了。希望大家多多点赞、收藏、评论支持，感谢！","resource-id":"com.smzdm.client.android:id\/tv_content","class":"android.widget.TextView","package":"com.smzdm.client.android","checkable":false,"checked":false,"clickable":false,"enabled":true,"focusable":false,"focused":false,"scrollable":false,"long-clickable":false,"password":false,"selected":false,"Visible":true,"boundsInParent":"(0, 0 - 788, 297)","boundsInScreen":"(215, 412 - 1003, 625)"},{"index":1,"text":"12","resource-id":"com.smzdm.client.android:id\/imgNum","class":"android.widget.